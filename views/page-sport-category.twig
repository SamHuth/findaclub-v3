{% extends "base.twig" %}

{% block content %}
	<div class="content-wrapper">
		<article class="post-type-{{post.post_type}}" id="post-{{post.ID}}">
			<section class="article-content py-lg">
				<h2 class="article-body">
					Join one of <span class="text-primary underline">{{ count }}</span> {{ sport_name }} clubs in Australia!
				</h2>
				<div class="article-body">
					{{post.content}}
				</div>
			</section>
			<section class="article-content py-lg">
				<h2 class="article-h2 text-center">Find Clubs by state</h2>
				<ul class="p-0 state-cards link-cards">
					{% for state in states %}
						{% include 'partial/state-card.twig' with {'state': state} %}
					{% endfor %}
				</ul>
			</section>
			<section class="article-content py-lg">
				<h2 class="article-h2 text-center">{{ sport }} Clubs with Opportunities</h2>
				<ul class="p-0 club-cards link-cards">
					{% for club in premium_clubs %}
						{% include 'partial/club-card.twig' with {'club': club} %}
					{% endfor %}
				</ul>
			</section>
		</article>
	</div><!-- /content-wrapper -->
{% endblock %}