{% extends "base.twig" %}

{% block content %}
	<div class="content-wrapper">
		<article class="post-type-{{post.post_type}}" id="post-{{post.ID}}">
			<section class="article-content">
				<div class="article-body">
					{{post.content}}
					<p>Page content.</p>
				</div>
				<h2>Find Clubs by league</h2>
				<h2>{{ sport_name }} clubs with opportunities</h2>
			</section>
		</article>
	</div><!-- /content-wrapper -->
{% endblock %}